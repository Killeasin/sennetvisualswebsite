---
import siteConfig from '../../site.config.mjs';
import { getCollections } from '../data/imageStore.ts';

const title = siteConfig.title;

const base = import.meta.env.BASE_URL;
const collections = await getCollections();
const hiddenCollectionIds = new Set(['featured', 'nature', 'street', 'travel']);
const menuItems = [
    { name: 'About Me', link: '/about' },
    ...collections
        .filter((collection) => !hiddenCollectionIds.has(collection.id))
        .map((collection) => ({
            name: collection.name,
            link: `${base}collections/${collection.id}`,
        })),
];
---
<div class="flex flex-col space-y-3 text-left font-medium text-gray-700">
    {
        menuItems.map((item) => (
            <a
                href={item.link}
                class="text-sm tracking-[0.2em] uppercase hover:text-black transition-colors relative block w-fit"
            >
                {item.name}
            </a>
        ))
    }
</div>