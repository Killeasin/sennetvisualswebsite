---
import siteConfig from '../../site.config.mjs';

const title = siteConfig.title;

const base = import.meta.env.BASE_URL;
const menuItems = [
    { name: 'About Me', link: '/about' },
    { name: 'Graduation', link: '/collections/graduation' },
    { name: 'Studio', link: '/collections/studio' },
    { name: 'Portraits', link: '/collections/portraits' },
    { name: 'Groups', link: '/collections/groups' },
    { name: 'Executive Boards', link: '/collections/boards' },
];
---
<div class="flex flex-col space-y-6 text-left font-medium text-gray-700">
    {
        menuItems.map((item) => (
            <a
                href={item.link}
                class="text-lg tracking-wide hover:text-black transition-colors relative block w-max"
            >
                {item.name}
            </a>
        ))
    }
</div>