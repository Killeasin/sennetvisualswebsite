---
import siteConfig from '../../site.config.mjs';
const owner = siteConfig.owner;
const currentYear = new Date().getFullYear();
const socialLinks = siteConfig.socialLinks;
---

<footer class="w-full text-left pt-6 border-t border-gray-100">
    <!-- Copyright block on its own line -->
    <p class="text-xs text-gray-500 tracking-wide leading-relaxed">
        &copy; {currentYear} {owner}. All rights reserved.
    </p>

    <!-- Social Icons Block directly underneath -->
    <div class="flex items-center space-x-4 mt-4">
        {
            socialLinks.map((social) => {
                const Icon = social.icon;
                return (
                    <a 
                        href={social.url} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        title={social.name}
                        class="text-gray-400 hover:text-black transition-colors"
                    >
                        <Icon class="h-4 w-4" />
                    </a>
                );
            })
        }
    </div>
</footer>