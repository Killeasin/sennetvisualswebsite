---
const { images } = Astro.props;
---

<div class="p-0 md:p-1">
  <div class="mx-auto columns-1 gap-3 sm:columns-2 md:columns-3 lg:columns-3" id="photo-grid">
    {images.map((image: any) => (
      <button
        type="button"
        class="mb-3 block w-full overflow-hidden bg-gray-50 break-inside-avoid group cursor-pointer relative text-left"
        data-image-src={image.src}
        data-image-title={image.title || "Portfolio Work"}
        aria-label={`Open image ${image.title || 'Portfolio Work'}`}
      >
        <img 
          src={image.src} 
          alt={image.title || "Portfolio Work"} 
          class="w-full h-full object-cover object-center transition-transform duration-500 ease-out group-hover:scale-105"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-black/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
      </button>
    ))}
  </div>

  <div id="image-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/80 px-4 py-6">
    <div class="relative flex h-full max-h-[90vh] w-full max-w-5xl items-center justify-center">
      <button
        type="button"
        id="close-image-modal"
        class="absolute right-2 top-2 z-10 rounded-full bg-white/90 px-3 py-2 text-sm font-medium text-gray-900 shadow-lg hover:bg-white"
        aria-label="Close image"
      >
        Close
      </button>
      <div id="modal-backdrop" class="absolute inset-0 cursor-zoom-out"></div>
      <img
        id="modal-image"
        src=""
        alt=""
        class="relative z-10 max-h-full max-w-full object-contain"
      />
    </div>
  </div>
</div>

<script>
  import '../scripts/photo-grid-modal.ts';
</script>