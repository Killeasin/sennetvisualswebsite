---
import '../styles/global.css';
import siteConfig from '../../site.config.mjs';
import Footer from '../components/Footer.astro';
import NavBar from '../components/NavBar.astro';

const owner = siteConfig.owner;
const favicon = siteConfig.favicon;
const base = import.meta.env.BASE_URL;
---

<html lang="en" class="h-full">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/x-icon" href={`${base}/${favicon}`} />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />

        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>{owner}</title>
    </head>
    <body class="h-full overflow-hidden">
        <div class="flex h-screen w-screen bg-[#faf9f6]">
            
            <!-- LEFT PANEL: Fixed Sidebar Navigation -->
            <aside class="w-56 h-screen bg-white border-r border-gray-100 flex flex-col justify-between p-5 shrink-0">
                <div>
                    <!-- Brand Identity Header -->
                    <div class="mb-8">
                        <h1 class="text-xl font-semibold tracking-tight text-gray-900">Sennet Visuals</h1>
                        <p class="text-[11px] text-gray-400 italic mt-1">Where Vision Meets Penn State</p>
                    </div>
                    
                    <!-- Native NavBar imports here -->
                    <NavBar /> 
                </div>
                
                <Footer />
            </aside>

            <!-- RIGHT PANEL: Scrollable Canvas Frame for Photos -->
            <main class="flex-1 h-screen overflow-y-auto px-6 py-6 md:px-10 md:py-8 lg:px-12 lg:py-10">
                <!-- The native page content injects here automatically -->
                <slot /> 
            </main>
            
        </div>
    </body>
</html>

<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>