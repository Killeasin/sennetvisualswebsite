			"label": "Move admin routes out of Astro pages",
			"type": "shell",
			"command": "if exist src\\pages\\admin move src\\pages\\admin src\\pages\\_admin && if exist src\\pages\\api\\admin move src\\pages\\api\\admin src\\pages\\api\\_admin && npm.cmd run build",
