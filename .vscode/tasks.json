		{
			"label": "Move admin routes out of Astro pages",
			"type": "shell",
			"command": "powershell -NoProfile -Command \"if (Test-Path 'src/pages/admin') { Move-Item -Force 'src/pages/admin' 'src/pages/_admin' }; if (Test-Path 'src/pages/api/admin') { Move-Item -Force 'src/pages/api/admin' 'src/pages/api/_admin' }; npm.cmd run build\"",
