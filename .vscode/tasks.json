			"type": "shell",
			"command": "cmd.exe /d /c \"cd /d c:\\mainFolder\\codeSoftware\\githubdesktop\\sennetvisualswebsite && if exist src\\pages\\admin move /Y src\\pages\\admin src\\pages\\_admin && if exist src\\pages\\api\\admin move /Y src\\pages\\api\\admin src\\pages\\api\\_admin\"",
			"problemMatcher": [],
			"group": "build"
		},
